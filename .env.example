# ============================================================
#  Mnemo — Twilio + WhatsApp configuration
#  Copy this file to `.env.local` and fill in the values.
# ============================================================

# ---- Twilio account ----
# https://console.twilio.com  →  Account SID & Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# The WhatsApp number messages will be sent FROM.
# - Sandbox (for testing):   whatsapp:+14155238886
# - Production (your own WhatsApp Business number): whatsapp:+15551234567
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: set to "true" to skip Twilio signature validation locally
# (e.g. when testing the webhook with ngrok). NEVER set this in production.
TWILIO_SKIP_VALIDATION=false


# ---- Frontend WhatsApp deep link (NEXT_PUBLIC_ = baked at build time) ----
# The number users land on when they tap "Try for Free" on the landing page.
# Use the SAME number as TWILIO_WHATSAPP_FROM (without the "whatsapp:" prefix).
NEXT_PUBLIC_WHATSAPP_NUMBER=+14155238886

# If you're on the Twilio sandbox, set the join code so the user's first
# message auto-fills as "join <code>". Leave empty in production.
# Find it in: Twilio Console → Messaging → Try it out → Send a WhatsApp message
NEXT_PUBLIC_WHATSAPP_JOIN_CODE=


# ---- Database (Upstash Redis) ----
# Free tier at https://console.upstash.com  →  Create database (Redis) →
# REST API tab. Copy both values exactly.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token


# ---- Cron dispatcher auth ----
# Generate any random string and pass as `Authorization: Bearer <value>`
# when calling GET /api/cron/dispatch. Required in production.
CRON_SECRET=replace-with-a-random-string


# ---- Google Calendar OAuth ----
# Create a project at https://console.cloud.google.com →
# Enable "Google Calendar API" + "Google People API" →
# OAuth consent screen (External, add scope calendar.events) →
# Credentials → OAuth 2.0 Client ID (Web application) →
# Add Authorized redirect URI: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/google/callback

# Base URL for building OAuth links sent over WhatsApp. Without scheme is fine.
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app


# ---- OpenAI (Whisper transcription for WhatsApp voice notes) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
