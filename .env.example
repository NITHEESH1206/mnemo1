# ============================================================
#  Feru AI — WhatsApp Cloud API (Meta) configuration
#  Copy this file to `.env.local` and fill in the values.
# ============================================================

# ---- WhatsApp Cloud API (Meta) ----
# developers.facebook.com → your app → WhatsApp → API setup
#
# Phone number ID of your sender (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=
# Access token. A temporary token works for testing; for production create a
# System User in Meta Business Settings and generate a permanent token.
WHATSAPP_ACCESS_TOKEN=
# Any random string you choose. You enter the SAME value in Meta's webhook
# config ("Verify token") so the GET handshake succeeds.
WHATSAPP_VERIFY_TOKEN=
# Meta app → Settings → Basic → App secret. Used to verify inbound webhooks.
# Leave blank during very early testing to skip signature checks.
WHATSAPP_APP_SECRET=
# Optional: Graph API version (defaults to v21.0).
WHATSAPP_GRAPH_VERSION=v21.0

# Reminders are business-initiated, so outside the 24h window they must use an
# approved Utility template. Create one in Meta (e.g. body: "⏰ Reminder: {{1}}")
# and put its name + language here. Leave blank to send free-form (only works
# if the user messaged you within the last 24h — fine for testing).
WHATSAPP_REMINDER_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=en


# ---- Frontend WhatsApp deep link (NEXT_PUBLIC_ = baked at build time) ----
# The number users land on when they tap "Try for Free" on the landing page.
# Your WhatsApp Business number, with country code (e.g. +919361092458).
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# Leave empty — only used for the old Twilio sandbox "join <code>" flow.
NEXT_PUBLIC_WHATSAPP_JOIN_CODE=


# ---- Database (Upstash Redis) ----
# Free tier at https://console.upstash.com  →  Create database (Redis) →
# REST API tab. Copy both values exactly.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token


# ---- Cron dispatcher auth ----
# Generate any random string and pass as `Authorization: Bearer <value>`
# when calling GET /api/cron/dispatch. Required in production.
CRON_SECRET=replace-with-a-random-string


# ---- Google Calendar OAuth ----
# Create a project at https://console.cloud.google.com →
# Enable "Google Calendar API" + "Google People API" →
# OAuth consent screen (External, add scope calendar.events) →
# Credentials → OAuth 2.0 Client ID (Web application) →
# Add Authorized redirect URI: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/google/callback

# Base URL for building OAuth links sent over WhatsApp. Without scheme is fine.
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app


# ---- OpenAI (Whisper transcription for WhatsApp voice notes) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ---- Razorpay (payments) ----
# https://dashboard.razorpay.com → Settings → API Keys → Generate Key
# Test keys start with rzp_test_ ; live keys with rzp_live_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=


# ---- Telegram bot (second channel) ----
# Create a bot with @BotFather → copy the token.
# TELEGRAM_WEBHOOK_SECRET is any random string you choose.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=


# ---- Microsoft (Outlook + Teams calendar) ----
# portal.azure.com → App registrations → New registration →
# Redirect URI (Web): https://<your-domain>/api/auth/microsoft/callback →
# Certificates & secrets → New client secret.
# Leave MICROSOFT_TENANT as "common" to allow any Microsoft account.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-domain.vercel.app/api/auth/microsoft/callback
MICROSOFT_TENANT=common


# ---- Notion (memory trunk) ----
# notion.so/my-integrations → New integration → type "Public" →
# add redirect URI: https://<your-domain>/api/auth/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://your-domain.vercel.app/api/auth/notion/callback


# ---- Email channel ----
# Outbound via Resend (resend.com → API Keys). EMAIL_FROM must be a
# verified domain sender, e.g. "Feru AI <feru@yourdomain.com>".
RESEND_API_KEY=
EMAIL_FROM=Feru AI <feru@yourdomain.com>
# Inbound: point your provider's inbound-parse webhook at
# /api/email/inbound?secret=<INBOUND_EMAIL_TOKEN>
INBOUND_EMAIL_TOKEN=
